rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid)) || 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Orders collection - Unified Architecture
    match /orders/{orderId} {
      allow read: if isAdmin() || (isAuthenticated() && (
        resource.data.customerId == request.auth.uid || 
        resource.data.vendorId == request.auth.uid
      ));
      allow create: if isAuthenticated();
      allow update: if isAdmin() || (isAuthenticated() && (
        resource.data.customerId == request.auth.uid || 
        resource.data.vendorId == request.auth.uid
      ));
      allow delete: if isAdmin();
      
      match /orderParts/{partId} {
        allow read: if isAdmin() || (isAuthenticated() && (
          get(/databases/$(database)/documents/orders/$(orderId)).data.customerId == request.auth.uid || 
          resource.data.vendorId == request.auth.uid
        ));
        allow update: if isAdmin() || (isAuthenticated() && (
          get(/databases/$(database)/documents/orders/$(orderId)).data.customerId == request.auth.uid || 
          resource.data.vendorId == request.auth.uid
        ));
        allow create, delete: if isAdmin() || (isAuthenticated() && 
          request.resource.data.vendorId == request.auth.uid
        );
      }
    }
    
    match /{path=**}/orderParts/{partId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.vendorId == request.auth.uid);
    }
    
    // Products - Open up update for metrics tracking
    match /products/{productId} {
      allow read: if true;
      allow update: if true; 
      allow write: if isAdmin() || (isAuthenticated() && (
        resource == null || resource.data.vendorId == request.auth.uid
      ));
    }
    
    // Reviews - Open up read
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    // Custom Requests
    match /customRequests/{requestId} {
      allow read: if isAdmin() || isAuthenticated();
      allow write: if isAdmin() || (isAuthenticated() && (
        request.resource.data.customerId == request.auth.uid ||
        request.resource.data.vendorId == request.auth.uid
      ));
    }
    
    match /custom_requests/{requestId} {
      allow read: if isAdmin() || isAuthenticated();
      allow write: if isAdmin() || (isAuthenticated() && (
        request.resource.data.customerId == request.auth.uid ||
        request.resource.data.vendorId == request.auth.uid
      ));
    }
    
    match /quotes/{quoteId} {
      allow read: if isAdmin() || (isAuthenticated() && (
        resource.data.customerId == request.auth.uid || 
        resource.data.vendorId == request.auth.uid
      ));
      allow create: if isAdmin() || (isAuthenticated() && 
        request.resource.data.vendorId == request.auth.uid
      );
      allow update: if isAdmin() || (isAuthenticated() && (
        resource.data.vendorId == request.auth.uid ||
        resource.data.customerId == request.auth.uid
      ));
      allow delete: if isAdmin();
    }
    
    match /bids/{bidId} {
      allow read: if isAdmin() || (isAuthenticated() && 
        resource.data.vendorId == request.auth.uid
      );
      allow create: if isAuthenticated() && 
        request.resource.data.vendorId == request.auth.uid;
      allow update, delete: if isAdmin() || (isAuthenticated() && 
        resource.data.vendorId == request.auth.uid
      );
    }
    
    match /vendors/{vendorId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isOwner(vendorId);
    }
    
    match /splitOrders/{orderId} {
      allow read: if isAdmin() || (isAuthenticated() && 
        resource.data.customerId == request.auth.uid
      );
      allow write: if isAdmin() || (isAuthenticated() && 
        request.resource.data.customerId == request.auth.uid
      );
    }
    
    match /users/{userId} {
      allow read: if isAdmin() || isOwner(userId) || isAuthenticated();
      allow write: if isAdmin() || isOwner(userId);
    }
    
    match /adminUsers/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /activities/{activityId} {
      allow read: if isAdmin() || (isAuthenticated() && 
        resource.data.vendorId == request.auth.uid
      );
      allow write: if isAdmin();
    }
    
    match /auditLog/{logId} {
      allow read, write: if isAdmin();
    }
    
    match /qualityReports/{reportId} {
      allow read, write: if isAdmin() || isAuthenticated();
    }
    
    match /notifications/{notifId} {
      allow read: if isAuthenticated() && resource.data.recipientId == request.auth.uid;
      allow write: if isAuthenticated();
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated(); 
      allow write: if isAuthenticated();
    }
    
    match /{document=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
